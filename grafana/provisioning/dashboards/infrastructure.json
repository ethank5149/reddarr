{
  "__inputs": [],
  "__requires": [],
  "annotations": {"list": []},
  "description": "PostgreSQL, Redis, system resources, and API performance",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 100,
      "title": "PostgreSQL",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false
    },
    {
      "id": 1,
      "title": "PostgreSQL Up",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_up", "instant": true, "legendFormat": "PG"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "UP"}, "0": {"text": "DOWN"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 2,
      "title": "Database Size",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 3, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_database_size_bytes{datname='reddit'}", "instant": true, "legendFormat": "DB Size"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}}
    },
    {
      "id": 3,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 7, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_database_numbackends{datname='reddit'}", "instant": true, "legendFormat": "Connections"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 4,
      "title": "Committed Transactions (5m rate)",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 10, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_xact_commit_total{datname='reddit'}[5m])", "instant": true, "legendFormat": "Commits/s"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 5,
      "title": "Rolled Back Transactions (5m rate)",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 14, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_xact_rollback_total{datname='reddit'}[5m])", "instant": true, "legendFormat": "Rollbacks/s"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 3, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.1}, {"color": "red", "value": 1}]}}}
    },
    {
      "id": 6,
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 3, "w": 5, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_database_blks_hit_total{datname='reddit'} / clamp_min(pg_stat_database_blks_hit_total{datname='reddit'} + pg_stat_database_blks_read_total{datname='reddit'}, 1) * 100", "instant": true, "legendFormat": "Hit Rate %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]}}}
    },
    {
      "id": 7,
      "title": "PG Connections Over Time",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "pg_stat_database_numbackends{datname='reddit'}", "legendFormat": "Connections"}],
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 8,
      "title": "PG Rows Inserted/Updated/Deleted",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_tup_inserted_total{datname='reddit'}[5m])", "legendFormat": "Inserts/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_tup_updated_total{datname='reddit'}[5m])", "legendFormat": "Updates/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_tup_deleted_total{datname='reddit'}[5m])", "legendFormat": "Deletes/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_tup_fetched_total{datname='reddit'}[5m])", "legendFormat": "Fetches/s"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 5}}}
    },
    {
      "id": 9,
      "title": "PG Deadlocks & Conflicts",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_deadlocks_total{datname='reddit'}[5m])", "legendFormat": "Deadlocks/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_conflicts_total{datname='reddit'}[5m])", "legendFormat": "Conflicts/s"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}, "color": {"mode": "fixed", "fixedColor": "red"}}}
    },
    {
      "id": 10,
      "title": "PG Temporary Files",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 11},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_temp_files_total{datname='reddit'}[5m])", "legendFormat": "Temp files/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(pg_stat_database_temp_bytes_total{datname='reddit'}[5m])", "legendFormat": "Temp bytes/s"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}}, "overrides": [{"matcher": {"id": "byName", "options": "Temp bytes/s"}, "properties": [{"id": "unit", "value": "Bps"}, {"id": "custom.axisPlacement", "value": "right"}]}]}
    },
    {
      "id": 101,
      "title": "Redis",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Redis Up",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "redis_up", "instant": true, "legendFormat": "Redis"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"1": {"text": "UP"}, "0": {"text": "DOWN"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 12,
      "title": "Redis Memory Used",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 3, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "redis_used_memory_bytes", "instant": true, "legendFormat": "Memory"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 536870912}, {"color": "red", "value": 1073741824}]}}}
    },
    {
      "id": 13,
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": {"h": 3, "w": 3, "x": 7, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "redis_connected_clients", "instant": true, "legendFormat": "Clients"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 14,
      "title": "Commands/s",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 10, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(redis_commands_processed_total[5m])", "instant": true, "legendFormat": "Cmds/s"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "id": 15,
      "title": "Media Queue Keys",
      "type": "stat",
      "gridPos": {"h": 3, "w": 4, "x": 14, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "reddit_queue_length", "instant": true, "legendFormat": "Queue"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}]}}}
    },
    {
      "id": 16,
      "title": "Keyspace Hit Rate",
      "type": "gauge",
      "gridPos": {"h": 3, "w": 5, "x": 18, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(redis_keyspace_hits_total[5m]) / clamp_min(rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]), 0.001) * 100", "instant": true, "legendFormat": "Hit Rate %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 70}, {"color": "green", "value": 90}]}}}
    },
    {
      "id": 17,
      "title": "Redis Memory Over Time",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "redis_used_memory_bytes", "legendFormat": "Used memory"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "redis_used_memory_rss_bytes", "legendFormat": "RSS memory"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 18,
      "title": "Redis Commands & Hits/Misses",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 21},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "Commands/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(redis_keyspace_hits_total[5m])", "legendFormat": "Hits/s"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(redis_keyspace_misses_total[5m])", "legendFormat": "Misses/s"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 102,
      "title": "System Resources",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28},
      "collapsed": false
    },
    {
      "id": 19,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)", "instant": true, "legendFormat": "CPU %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 20,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "instant": true, "legendFormat": "Memory %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 21,
      "title": "Disk Usage (root)",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "(1 - node_filesystem_avail_bytes{mountpoint='/',fstype!='tmpfs'} / node_filesystem_size_bytes{mountpoint='/',fstype!='tmpfs'}) * 100", "instant": true, "legendFormat": "Disk %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdMarkers": true},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 22,
      "title": "Available Memory",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 29},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "node_memory_MemAvailable_bytes", "instant": true, "legendFormat": "Available"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 536870912}, {"color": "green", "value": 2147483648}]}}}
    },
    {
      "id": 23,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)", "legendFormat": "Total CPU %"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by(instance) (rate(node_cpu_seconds_total{mode='user'}[5m])) * 100", "legendFormat": "User %"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by(instance) (rate(node_cpu_seconds_total{mode='system'}[5m])) * 100", "legendFormat": "System %"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "avg by(instance) (rate(node_cpu_seconds_total{mode='iowait'}[5m])) * 100", "legendFormat": "IOWait %"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2, "fillOpacity": 5}}}
    },
    {
      "id": 24,
      "title": "Memory Over Time",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 33},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "node_memory_MemAvailable_bytes", "legendFormat": "Available"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes", "legendFormat": "Cached+Buffers"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 25,
      "title": "Disk I/O",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "Read Bytes/s ({{device}})"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "Write Bytes/s ({{device}})"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 26,
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_network_receive_bytes_total{device!~'lo|veth.*|docker.*|br.*'}[5m])", "legendFormat": "RX ({{device}})"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(node_network_transmit_bytes_total{device!~'lo|veth.*|docker.*|br.*'}[5m])", "legendFormat": "TX ({{device}})"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 103,
      "title": "API Performance",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 47},
      "collapsed": false
    },
    {
      "id": 27,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum by (status_code) (rate(http_requests_total[5m]))", "legendFormat": "HTTP {{status_code}}"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(http_requests_total[5m]))", "legendFormat": "Total req/s"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 5}}}
    },
    {
      "id": 28,
      "title": "API Request Duration Percentiles",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99"}
      ],
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}}}
    },
    {
      "id": 29,
      "title": "Top API Endpoints by Request Rate",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 56},
