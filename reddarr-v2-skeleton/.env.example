# =============================================================================
# Reddarr v2 Configuration
# =============================================================================

# --- Required ---
POSTGRES_PASSWORD=changeme

# Reddit API credentials (also stored as Docker secrets)
REDDIT_USER_AGENT=Reddarr/2.0 (self-hosted archiver; https://github.com/ethank5149/reddarr)

# --- Paths ---
ARCHIVE_PATH=/mnt/user/Archive/reddit
THUMB_PATH=/mnt/user/Archive/reddit/.thumbs
ARCHIVE_MEDIA_PATH=/mnt/user/Archive/reddit/.archive

# --- Scheduling ---
POLL_INTERVAL=300        # Seconds between ingest cycles
SCRAPE_LIMIT=500         # Max posts to fetch per target per cycle

# --- Ports ---
REDDARR_PORT=8011        # Web UI / API
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# --- Logging ---
LOG_LEVEL=INFO

# --- Database pool ---
DB_POOL_MIN=2
DB_POOL_MAX=20
